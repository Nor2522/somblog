# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=somblog

# Admin login (generate the hash with: npm run generate-hash "your-password")
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Session signing secret (any long random string, e.g. output of: openssl rand -hex 32)
JWT_SECRET=

# Vercel sets this automatically in production - leave unset locally
NODE_ENV=development
